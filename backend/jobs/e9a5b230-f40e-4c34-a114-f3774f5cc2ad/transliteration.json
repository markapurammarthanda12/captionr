[
  {
    "start": 0.0,
    "end": 4.98,
    "text": "\u0c05\u0c38\u0c32\u0c4d \u0c17\u0c4d\u0c32\u0c4b\u0c2c\u0c32\u0c4d \u0c35\u0c3e\u0c30\u0c4d\u0c2e\u0c47\u0c36\u0c28\u0c4d \u0c05\u0c02\u0c1f\u0c47\u0c02\u0c1f\u0c4b \u0c26\u0c47\u0c32\u0c4d\u0c38\u0c3e \u0c38\u0c30\u0c4d \u0c2e\u0c3f\u0c15\u0c41? \u0c21\u0c3f\u0c2b\u0c47\u0c28\u0c4d\u0c38\u0c4d \u0c32\u0c4b\u0c2f\u0c30\u0c4d \u0c38\u0c4b\u0c2e\u0c36\u0c47\u0c15\u0c30\u0c4d \u0c17\u0c3e\u0c30\u0c41?",
    "transliterated": "Asalu global v\u0101rm\u0113\u015bana\u1e43 \u0101nt\u0113\u1e43\u1e6d\u014d d\u0113l\u1e63\u0101 sar miku? \u1e0dif\u0113ns l\u014dyara s\u014dma\u015b\u0113kara ga\u1e5fu?"
  },
  {
    "start": 4.98,
    "end": 6.18,
    "text": "\u0c28\u0c3e \u0c2a\u0c47\u0c30\u0c41 \u0c38\u0c4b\u0c2a\u0c38\u0c47\u0c15\u0c30\u0c4d \u0c15\u0c3e\u0c26\u0c41",
    "transliterated": "N\u0101 p\u0113ru s\u014dpasekara k\u0101\u1e0du"
  },
  {
    "start": 6.18,
    "end": 7.6,
    "text": "\u0c38\u0c42\u0c37\u0c3f\u0c28\u0c4d \u0c30\u0c3e \u0c26\u0c4d\u0c35\u0c3e\u0c30\u0c4d\u0c15\u0c3e \u0c2a\u0c4d\u0c30\u0c38\u0c26\u0c4d \u0c17\u0c3e\u0c30\u0c41",
    "transliterated": "S\u016b\u1e63in r\u0101 dv\u0101rk\u0101 prasada ga\u1e5fu"
  },
  {
    "start": 7.6,
    "end": 8.4,
    "text": "\u0c26\u0c4d\u0c35\u0c3e\u0c30\u0c4d\u0c15\u0c3e \u0c2a\u0c4d\u0c30\u0c38\u0c26\u0c4d \u0c06\u0c26\u0c41",
    "transliterated": "Dv\u0101rk\u0101 prasada \u0101du"
  },
  {
    "start": 8.4,
    "end": 8.9,
    "text": "\u0c2a\u0c3e\u0c21\u0c41 \u0c35\u0c21\u0c41",
    "transliterated": "P\u0101\u1e0du va\u1e0du"
  },
  {
    "start": 8.9,
    "end": 15.44,
    "text": "\u0c07\u0c30\u0c4b\u0c1c\u0c41 \u0c38\u0c4b\u0c38\u0c3e\u0c2f\u0c1f\u0c3f\u0c32\u0c4b\u0c28\u0c4d\u0c28 \u0c2a\u0c4d\u0c30\u0c3e\u0c2c\u0c4d\u0c32\u0c02\u0c38\u0c4d \u0c17\u0c41\u0c30\u0c3f\u0c02\u0c1a \u0c06\u0c32\u0c1a\u0c41\u0c38\u0c4d\u0c24\u0c41\u0c02\u0c1f\u0c47 \u0c28\u0c3e\u0c15\u0c41 \u0c17\u0c42\u0c38\u0c4d \u0c2a\u0c3f\u0c02\u0c2a\u0c4d\u0c2a\u0c41\u0c32\u0c4d\u0c38\u0c4d \u0c09\u0c38\u0c4d\u0c24\u0c41\u0c02\u0c26\u0c47 \u0c38\u0c30\u0c4d",
    "transliterated": "Ir\u014dju s\u014ds\u0101yati\u1e37\u014dnna pr\u0101bl\u0101mblas gu\u1e5fi\u00f1ca \u0101lacu\u1e63\u1e6du\u1e47\u1e6da n\u0101ku g\u016bsa pi\u1e43ppul\u1e63 u\u1e63\u1e6du\u1e47\u1e0d\u0113 sar"
  },
  {
    "start": 15.44,
    "end": 18.92,
    "text": "\u0c05\u0c38\u0c32\u0c4d \u0c17\u0c42\u0c38\u0c4d \u0c2a\u0c3f\u0c02\u0c2a\u0c4d\u0c2a\u0c41\u0c32\u0c4d\u0c38\u0c4d \u0c17\u0c42\u0c30\u0c3f\u0c02\u0c1a \u0c05\u0c32\u0c1a\u0c41\u0c38\u0c4d\u0c24\u0c41\u0c24\u0c47 \u0c2e\u0c32\u0c4d\u0c32 \u0c17\u0c42\u0c38\u0c4d \u0c2a\u0c3f\u0c02\u0c2a\u0c4d\u0c2a\u0c41\u0c32\u0c4d\u0c38\u0c4d \u0c35\u0c38\u0c4d\u0c24\u0c41\u0c28\u0c47 \u0c38\u0c3e\u0c30\u0c4d",
    "transliterated": "Asalu g\u016bsa pi\u1e43ppul\u1e63 gu\u1e5fi\u00f1ca alacu\u1e63\u1e6du\u1e6da malla g\u016bsa pi\u1e43ppul\u1e63 vas\u1e6du\u1e47\u0113 sar"
  },
  {
    "start": 18.92,
    "end": 22.22,
    "text": "\u0c09\u0c28\u0c4d\u0c28\u0c4b\u0c32\u0c41 \u0c32\u0c47\u0c28\u0c4b\u0c32\u0c41 \u0c12\u0c15 \u0c1c\u0c3e\u0c17\u0c32\u0c41 \u0c09\u0c02\u0c21\u0c3e\u0c26\u0c4d\u0c26\u0c3e \u0c38\u0c3e\u0c30\u0c4d",
    "transliterated": "Un\u1e47\u014dlu l\u0113n\u014dlu oka j\u0101gala u\u1e47\u1e0d\u0101\u1e0da sar"
  },
  {
    "start": 22.22,
    "end": 24.62,
    "text": "\u0c2e\u0c3f\u0c32\u0c41 \u0c09\u0c28\u0c4d\u0c28\u0c3e\u0c30\u0c41 \u0c15\u0c3f\u0c02\u0c26\u0c30\u0c3e \u0c15\u0c3e\u0c28\u0c4d \u0c2e\u0c47\u0c2e\u0c41 \u0c32\u0c47\u0c28\u0c4b\u0c32\u0c2e\u0c41 \u0c15\u0c3e \u0c38\u0c3e\u0c30\u0c4d",
    "transliterated": "Mila u\u1e47\u1e47\u0101ru ki\u1e43dar\u0101 k\u0101na m\u0113mu l\u0113n\u014dlamu k\u0101 sar"
  },
  {
    "start": 24.62,
    "end": 28.08,
    "text": "\u0c15\u0c4b\u0c1f\u0c4d \u0c32\u0c4b \u0c09\u0c28\u0c4d\u0c28\u0c3e\u0c32\u0c41 \u0c32\u0c47\u0c28\u0c4b\u0c32\u0c21\u0c41 \u0c05\u0c28\u0c47 \u0c24\u0c46\u0c21\u0c3e \u0c09\u0c02\u0c21\u0c3e\u0c26\u0c41",
    "transliterated": "K\u014d\u1e6d\u1e6da l\u014d u\u1e47\u1e47\u0101lu l\u0113n\u014dlamu \u0101\u1e47\u0113 t\u0113\u1e0da u\u1e47\u1e0d\u0101\u1e0du"
  },
  {
    "start": 28.08,
    "end": 33.42,
    "text": "\u0c07\u0c26\u0c41\u0c15\u0c4b\u0c1f\u0c4d\u0c1f\u0c41\u0c28\u0c4b \u0c38\u0c3e\u0c30\u0c4d \u0c07\u0c2a\u0c41\u0c21\u0c4d \u0c15\u0c4b\u0c1f\u0c4d\u0c1f\u0c41\u0c28\u0c4b \u0c09\u0c28\u0c4d\u0c28\u0c3e\u0c30\u0c41 \u0c07\u0c21\u0c41\u0c28\u0c4b\u0c30\u0c41 \u0c2e\u0c30\u0c41 \u0c32\u0c47\u0c28\u0c4b\u0c32\u0c4d\u0c32\u0c41 \u0c32\u0c47\u0c28\u0c1f\u0c4d\u0c1f\u0c47 \u0c38\u0c42\u0c38\u0c3f\u0c28\u0c4d\u0c28\u0c30\u0c3e \u0c38\u0c3e\u0c30\u0c4d \u0c32\u0c47\u0c28\u0c4b\u0c32\u0c4d\u0c32\u0c4d\u0c32\u0c02\u0c1f\u0c47 \u0c05\u0c02\u0c24\u0c3e \u0c1a\u0c3f\u0c28\u0c4d\u0c28 \u0c1a\u0c42\u0c2a\u0c4d\u0c2a\u0c3e",
    "transliterated": "Iduk\u014d\u1e6d\u1e6du\u1e47\u014d sar ipu\u1e0d k\u014d\u1e6d\u1e6du\u1e47\u014d u\u1e47\u1e47\u0101ru i\u1e0du\u1e47\u014dru maru l\u0113n\u014dllu l\u0113na\u1e6d\u1e6d\u0113 s\u016bsi\u1e47\u1e47ar\u0101 sar l\u0113n\u014dlll\u0101\u1e43\u1e6d\u0113 ant\u0101 ci\u1e47\u1e47a c\u016bpp\u0101"
  },
  {
    "start": 33.42,
    "end": 63.4,
    "text": "\u0c2e\u0c3e\u0c2e\u0c3e \u0c07\u0c26\u0c4d\u0c26\u0c3e\u0c2e\u0c3e \u0c28\u0c3f\u0c15\u0c41\u0c1f\u0c4d\u0c1f\u0c30\u0c3e \u0c2e\u0c3e\u0c2e\u0c3e",
    "transliterated": "M\u0101m\u0101 id\u1e0d\u0101m\u0101 nikku\u1e6d\u1e6dar\u0101 m\u0101m\u0101"
  },
  {
    "start": 63.42,
    "end": 65.76,
    "text": "\u0c2a\u0c46\u0c38\u0c4d\u0c1f\u0c41\u0c2a\u0c47\u0c36\u0c28\u0c4d \u0c06\u0c2f\u0c02 \u0c38\u0c4d\u0c1f\u0c3f\u0c32\u0c4d \u0c05\u0c28\u0c4d\u0c15\u0c4d\u0c30\u0c3f\u0c2e\u0c3f\u0c28\u0c32\u0c4d \u0c1f\u0c40\u0c32\u0c4d \u0c2a\u0c4d\u0c30\u0c42\u0c2b\u0c4d",
    "transliterated": "P\u0113\u1e63\u1e6dup\u0113\u015bana \u0101yam stila\u1e45k\u1e5bimina\u1e6d\u012bl pr\u016bpha"
  },
  {
    "start": 65.76,
    "end": 67.18,
    "text": "\u0c15\u0c3e\u0c28\u0c4d\u0c38\u0c4d\u0c1f\u0c41\u0c1f\u0c4d\u0c2f\u0c42\u0c36\u0c28\u0c4d \u0c30\u0c3e\u0c27\u0c3f",
    "transliterated": "K\u0101ns\u1e6du\u1e6dy\u016b\u015bana r\u0101\u1e0dhi"
  },
  {
    "start": 67.18,
    "end": 97.18,
    "text": "\u0c2e\u0c3e\u0c2e\u0c3e \u0c2e\u0c3e\u0c28\u0c4d \u0c32\u0c3e\u0c07\u0c2b\u0c4d \u0c32\u0c4b \u0c32\u0c3e\u0c07\u0c2b\u0c4d \u0c0e\u0c02\u0c21\u0c3f \u0c38\u0c3f\u0c1f\u0c4d\u0c35\u0c3f\u0c37\u0c3f\u0c02\u0c26\u0c3f \u0c35\u0c3f\u0c37\u0c4d\u0c1a\u0c3f\u0c38\u0c3f\u0c02\u0c26\u0c3f \u0c30\u0c3e \u0c2e\u0c28 \u0c2e\u0c41\u0c17\u0c4d\u0c17\u0c41\u0c30\u0c41 \u0c32\u0c4b \u0c15\u0c4b\u0c21\u0c3f \u0c38\u0c1a\u0c4d\u0c1a\u0c3f\u0c2a\u0c47\u0c28\u0c3e \u0c2a\u0c30\u0c32\u0c47\u0c26\u0c4d \u0c2e\u0c3f\u0c24\u0c4d\u0c24\u0c3e \u0c07\u0c26\u0c4d\u0c26\u0c30\u0c41 \u0c38\u0c02\u0c24\u0c4b\u0c37\u0c02\u0c17\u0c41\u0c02\u0c1f\u0c47",
    "transliterated": "M\u0101m\u0101 m\u0101na la\u012bf l\u014d la\u012bf \u0113\u1e43\u1e0di si\u1e6dvi\u1e63i\u1e47\u1e0di vi\u1e63ci\u1e63i\u1e47\u1e0di r\u0101 mana muggu\u1e5fu l\u014d k\u014d\u1e0di sacchi p\u0113\u1e47\u0101 paral\u0113\u1e0da mit\u1e6d\u0101 id\u1e0daru sa\u1e43\u1e6do\u1e63a\u1e45gu\u1e47\u1e6d\u0113"
  },
  {
    "start": 97.18,
    "end": 99.46,
    "text": "\u0c2e\u0c41\u0c02\u0c26\u0c41\u0c15\u0c4d\u0c30\u0c3e\u0c28\u0c3e \u0c28\u0c3f\u0c2f\u0c3e\u0c2a\u0c3e",
    "transliterated": "Mu\u1e47\u1e0dukr\u0101\u1e47\u0101 niy\u0101p\u0101"
  }
]