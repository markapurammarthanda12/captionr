[
  {
    "start": 0.0,
    "end": 4.98,
    "text": "\u0c05\u0c38\u0c32\u0c4d \u0c17\u0c4d\u0c32\u0c4b\u0c2c\u0c32\u0c4d \u0c35\u0c3e\u0c30\u0c4d\u0c2e\u0c47\u0c36\u0c28\u0c4d \u0c05\u0c02\u0c1f\u0c47\u0c02\u0c1f\u0c4b \u0c26\u0c47\u0c32\u0c4d\u0c38\u0c3e \u0c38\u0c30\u0c4d \u0c2e\u0c3f\u0c15\u0c41? \u0c21\u0c3f\u0c2b\u0c47\u0c28\u0c4d\u0c38\u0c4d \u0c32\u0c4b\u0c2f\u0c30\u0c4d \u0c38\u0c4b\u0c2e\u0c36\u0c47\u0c15\u0c30\u0c4d \u0c17\u0c3e\u0c30\u0c41?",
    "transliterated": "Asalu global v\u0101rm\u0113\u015bana\u1e43 \u0101nt\u0113\u1e43\u1e6d\u014d d\u0113l\u1e63\u0101 sar miku? \u1e0dif\u0113\u1e47\u1e63 l\u014dyara somash\u0113kara ga\u1e5fu?"
  },
  {
    "start": 4.98,
    "end": 6.22,
    "text": "\u0c28\u0c3e \u0c2a\u0c47\u0c30\u0c41 \u0c38\u0c4b\u0c2a\u0c38\u0c47\u0c15\u0c30\u0c4d \u0c15\u0c3e\u0c26\u0c41",
    "transliterated": "N\u0101 p\u0113ru sopash\u0113kara k\u0101\u1e0du"
  },
  {
    "start": 6.22,
    "end": 7.62,
    "text": "\u0c38\u0c42\u0c37\u0c3f\u0c28\u0c4d \u0c30\u0c3e \u0c26\u0c4d\u0c35\u0c3e\u0c30\u0c4d\u0c15\u0c3e \u0c2a\u0c4d\u0c30\u0c38\u0c26\u0c4d \u0c17\u0c3e\u0c30\u0c41",
    "transliterated": "S\u016b\u1e63i\u1e47 ra dv\u0101rka prasada ga\u1e5fu"
  },
  {
    "start": 7.62,
    "end": 8.38,
    "text": "\u0c26\u0c4d\u0c35\u0c3e\u0c30\u0c4d\u0c15\u0c3e \u0c2a\u0c4d\u0c30\u0c38\u0c26\u0c4d \u0c06\u0c26\u0c41",
    "transliterated": "Dv\u0101rka prasada \u0101du"
  },
  {
    "start": 8.38,
    "end": 8.94,
    "text": "\u0c2a\u0c3e\u0c21\u0c41 \u0c35\u0c21\u0c41",
    "transliterated": "P\u0101\u1e0du va\u1e0du"
  },
  {
    "start": 8.94,
    "end": 15.44,
    "text": "\u0c07\u0c30\u0c4b\u0c1c\u0c41 \u0c38\u0c4b\u0c38\u0c3e\u0c2f\u0c1f\u0c3f\u0c32\u0c4b\u0c28\u0c4d\u0c28 \u0c2a\u0c4d\u0c30\u0c3e\u0c2c\u0c4d\u0c32\u0c02\u0c38\u0c4d \u0c17\u0c41\u0c30\u0c3f\u0c02\u0c1a \u0c06\u0c32\u0c1a\u0c41\u0c38\u0c4d\u0c24\u0c41\u0c02\u0c1f\u0c47 \u0c28\u0c3e\u0c15\u0c41 \u0c17\u0c42\u0c38\u0c4d \u0c2a\u0c3f\u0c02\u0c2a\u0c4d\u0c2a\u0c41\u0c32\u0c4d\u0c38\u0c4d \u0c09\u0c38\u0c4d\u0c24\u0c41\u0c02\u0c26\u0c47 \u0c38\u0c30\u0c4d",
    "transliterated": "Ir\u014dju s\u014ds\u0101yati\u1e37\u014dnna pr\u0101blama ga\u1e5fi\u1e45\u1e0da \u0101lacu\u1e63\u1e6du\u1e47\u1e6da n\u0101ku g\u016bsa pi\u1e41pu\u1e37u\u1e37u\u1e63\u1e6du\u1e47\u1e0d\u0113 sar"
  },
  {
    "start": 15.44,
    "end": 18.92,
    "text": "\u0c05\u0c38\u0c4d\u0c32 \u0c17\u0c42\u0c38\u0c4d \u0c2a\u0c4d\u0c2a\u0c41\u0c32\u0c4d\u0c38\u0c4d \u0c17\u0c42\u0c30\u0c3f\u0c02\u0c1a \u0c05\u0c32\u0c1a\u0c41\u0c38\u0c4d\u0c24\u0c41\u0c1f\u0c47 \u0c2e\u0c32\u0c4d\u0c32 \u0c17\u0c42\u0c38\u0c4d \u0c2a\u0c4d\u0c2a\u0c41\u0c32\u0c4d\u0c38\u0c4d \u0c09\u0c38\u0c4d\u0c24\u0c41\u0c28\u0c47 \u0c38\u0c3e\u0c30\u0c4d",
    "transliterated": "Asala g\u016bsa ppu\u1e37u ga\u1e5fi\u1e45\u1e0da alacu\u1e63\u1e6du\u1e6da mall\u0101 g\u016bsa ppu\u1e37u\u1e37u\u1e63\u1e6du\u1e47\u0113 sar"
  },
  {
    "start": 18.92,
    "end": 22.22,
    "text": "\u0c09\u0c28\u0c4d\u0c28\u0c4b\u0c32\u0c41 \u0c32\u0c47\u0c28\u0c4b\u0c32\u0c41 \u0c12\u0c15 \u0c1c\u0c3e\u0c17\u0c32\u0c41 \u0c09\u0c02\u0c21\u0c3e\u0c26\u0c4d\u0c26\u0c3e \u0c38\u0c3e\u0c30\u0c4d",
    "transliterated": "Unn\u014dlu l\u0113n\u014dlu oka j\u0101gala u\u1e47\u1e0d\u0101\u1e0da sar"
  },
  {
    "start": 22.22,
    "end": 24.62,
    "text": "\u0c2e\u0c3f\u0c32\u0c41 \u0c09\u0c28\u0c4d\u0c28\u0c3e\u0c30\u0c41 \u0c15\u0c3f\u0c02\u0c26\u0c30\u0c3e \u0c15\u0c3e\u0c28\u0c4d \u0c2e\u0c47\u0c2e\u0c41 \u0c32\u0c47\u0c28\u0c4b\u0c32\u0c41 \u0c2e\u0c3f\u0c32\u0c41 \u0c38\u0c3e\u0c30\u0c4d",
    "transliterated": "Mila u\u1e47\u1e47\u0101ru ki\u1e41dar\u0101 k\u0101na m\u0113mu l\u0113n\u014dlu milu sar"
  },
  {
    "start": 24.62,
    "end": 28.08,
    "text": "\u0c15\u0c4b\u0c1f\u0c4d \u0c32\u0c4b \u0c09\u0c28\u0c4d\u0c28\u0c3e\u0c32\u0c41 \u0c32\u0c47\u0c28\u0c4b\u0c32\u0c41 \u0c05\u0c28\u0c47 \u0c24\u0c46\u0c21\u0c3e \u0c09\u0c02\u0c21\u0c3e\u0c26\u0c41",
    "transliterated": "K\u014d\u1e6d\u1e6da l\u014d u\u1e47\u1e47\u0101lu l\u0113n\u014dlu an\u0113 \u1e6d\u0113\u1e0da u\u1e47\u1e0d\u0101\u1e0du"
  },
  {
    "start": 28.08,
    "end": 58.08,
    "text": "\u0c07\u0c02\u0c26\u0c41\u0c15\u0c4b\u0c1f\u0c4d\u0c1f\u0c3e\u0c32\u0c4d \u0c38\u0c3e\u0c30\u0c4d \u0c07\u0c2a\u0c41\u0c21\u0c4d \u0c15\u0c4b\u0c1f\u0c4d\u0c1f\u0c32\u0c4b \u0c09\u0c28\u0c4d\u0c28\u0c32\u0c4d\u0c32\u0c02\u0c26\u0c30\u0c3f \u0c07\u0c21\u0c41\u0c28\u0c4d\u0c28\u0c3e\u0c30\u0c41 \u0c2e\u0c30\u0c41 \u0c32\u0c47\u0c28\u0c3e\u0c32\u0c4d\u0c32\u0c41 \u0c32\u0c47\u0c28\u0c3e\u0c32\u0c4d\u0c32\u0c41 \u0c38\u0c42\u0c38\u0c3f\u0c28\u0c4d\u0c28\u0c30\u0c3e \u0c38\u0c3e\u0c30\u0c4d \u0c32\u0c47\u0c28\u0c3e\u0c32\u0c4d\u0c32\u0c41\u0c02\u0c32\u0c02\u0c1f\u0c47 \u0c05\u0c02\u0c24\u0c3e \u0c1a\u0c3f\u0c28\u0c4d\u0c28 \u0c1a\u0c42",
    "transliterated": "Induk\u014d\u1e6d\u1e6d\u0101la sar ipu\u1e0d k\u014d\u1e6d\u1e6dal\u014d u\u1e47\u1e47\u0101l l\u0101ndar\u0101 idu\u1e47\u1e47\u0101ru maru l\u0113n\u0101l l\u0101l l\u0113n\u0101l l\u0101l s\u016bsi\u1e47nar\u0101 sar l\u0113n\u0101l l\u0101l l\u0101manta chinna c\u016b"
  },
  {
    "start": 58.08,
    "end": 60.08,
    "text": "\u0c24\u0c47\u0c32\u0c41\u0c02\u0c1f\u0c4d \u0c07\u0c35\u0c02\u0c21\u0c3f \u0c24\u0c3e\u0c2f\u0c30\u0c41 \u0c17\u0c3e\u0c30\u0c41 \u0c1c\u0c46\u0c2a\u0c4d\u0c24\u0c41\u0c28\u0c3e\u0c30\u0c41 \u0c17\u0c3e\u0c30\u0c41",
    "transliterated": "T\u0113lu\u1e47\u1e6da ivam\u1e47\u1e0di t\u0101yar ga\u1e5fu jep\u1e6dun\u0101ru ga\u1e5fu"
  },
  {
    "start": 60.08,
    "end": 65.08,
    "text": "\u0c24\u0c24\u0c3f\u0c37\u0c4d \u0c05\u0c15\u0c3e\u0c21\u0c3f\u0c02\u0c1f\u0c41 \u0c07\u0c02\u0c21\u0c3f\u0c2f\u0c28\u0c4d \u0c15\u0c3e\u0c28\u0c4d\u0c38\u0c4d\u0c1f\u0c41\u0c2a\u0c47\u0c36\u0c28\u0c4d \u0c06\u0c2f\u0c02 \u0c38\u0c4d\u0c1f\u0c3f\u0c32\u0c4d \u0c05\u0c28\u0c4d\u0c15\u0c4d\u0c30\u0c3f\u0c2e\u0c3f\u0c28\u0c32\u0c4d \u0c1f\u0c3f\u0c32\u0c4d \u0c2a\u0c4d\u0c30\u0c42\u0c2b\u0c4d",
    "transliterated": "Tati\u1e63 a\u1e37a\u1e0di\u1e43\u1e6du i\u1e47\u1e0diyani ka\u1e45\u1e63\u1e6du p\u0113\u015ba\u1e43 \u0101yam stil a\u1e45kri\u1e37i\u1e43i\u1e47al \u1e6di\u1e37 pr\u016bpha"
  },
  {
    "start": 65.08,
    "end": 67.08,
    "text": "\u0c2a\u0c4d\u0c30\u0c42\u0c2b \u0c15\u0c3e\u0c28\u0c4d\u0c38\u0c4d\u0c1f\u0c41\u0c1f\u0c4d\u0c2f\u0c42\u0c36\u0c28\u0c4d\u0c28\u0c3f \u0c30\u0c3e\u0c26\u0c3f",
    "transliterated": "Pr\u016bpha ka\u1e45\u1e63\u1e6du\u1e6dy\u016b\u015ba\u1e47\u1e47i r\u0101\u1e0di"
  },
  {
    "start": 67.08,
    "end": 71.08,
    "text": "\u0c2e\u0c3e\u0c2e\u0c3e \u0c2e\u0c3e\u0c28\u0c4d\u0c28\u0c3e \u0c32\u0c3e\u0c07\u0c2b\u0c32\u0c4b \u0c32\u0c3e\u0c07\u0c2b\u0c30\u0c4b\u0c02\u0c21\u0c47 \u0c38\u0c3f\u0c1f\u0c4d\u0c35\u0c47\u0c36\u0c28\u0c4d\u0c28\u0c3f \u0c09\u0c1a\u0c4d\u0c1a\u0c47\u0c38\u0c3f\u0c02\u0c26\u0c30\u0c3e",
    "transliterated": "M\u0101m\u0101 m\u0101nn\u0101 l\u0101i\u1e37aph\u014d l\u0101i\u1e37ar\u014d\u1e47\u1e0da si\u1e6dv\u0113\u015ba\u1e47\u1e47i ucc\u0113si\u1e47\u1e0dar\u0101"
  },
  {
    "start": 71.08,
    "end": 75.46,
    "text": "\u0c2e\u0c3e\u0c28 \u0c2e\u0c41\u0c17\u0c4d\u0c17\u0c41\u0c30\u0c41\u0c32\u0c4b \u0c15\u0c4b\u0c21\u0c3f \u0c38\u0c1a\u0c4d\u0c1a\u0c3f\u0c2a\u0c47\u0c28\u0c3e \u0c2a\u0c30\u0c32\u0c47\u0c26\u0c4d \u0c2e\u0c3f\u0c24\u0c3e \u0c07\u0c26\u0c4d\u0c26\u0c30\u0c41 \u0c38\u0c02\u0c24\u0c4b\u0c37\u0c02\u0c17\u0c41\u0c02\u0c1f\u0c47 \u0c38\u0c3e\u0c32\u0c4d\u0c21\u0c3e",
    "transliterated": "M\u0101na muggu\u1e37u l\u014d k\u014d\u1e0di saccipp\u0113n\u0101 paral\u0113\u1e0da mita id\u1e0daru sant\u014d\u1e63a\u1e45gu\u1e47\u1e6da s\u0101\u1e37\u1e0da"
  },
  {
    "start": 75.46,
    "end": 79.3,
    "text": "\u0c2e\u0c3e\u0c2e\u0c3e \u0c2e\u0c3f\u0c26\u0c4d\u0c26\u0c30\u0c41\u0c32\u0c4b \u0c12\u0c15\u0c4d\u0c15\u0c21\u0c4b\u0c30\u0c4b \u0c21\u0c3f\u0c38\u0c3e\u0c21\u0c4d\u0c2f\u0c38\u0c4d\u0c15\u0c41\u0c02\u0c21\u0c3e",
    "transliterated": "M\u0101m\u0101 mid\u1e0daru l\u014d oka\u1e0d\u014dr\u014d \u1e0dis\u0101\u1e0dyasku\u1e47\u1e0d\u0101"
  },
  {
    "start": 79.3,
    "end": 106.76,
    "text": "\u0c2e\u0c3e\u0c2e\u0c3e \u0c2e\u0c3e \u0c2e\u0c41\u0c17\u0c4d\u0c17\u0c32\u0c4d\u0c32 \u0c28\u0c41\u0c2c\u0c40 \u0c17\u0c3e\u0c26\u0c30\u0c3e \u0c07\u0c02\u0c26\u0c3f \u0c2c\u0c15\u0c30\u0c3e\u0c17\u0c3e\u0c02\u0c21\u0c3e \u0c2e\u0c3f\u0c15\u0c4d \u0c2a\u0c3e\u0c35\u0c30\u0c41\u0c02\u0c26\u0c3f \u0c2e\u0c3e\u0c15\u0c41 \u0c2c\u0c4d\u0c30\u0c47\u0c28\u0c4d \u0c09\u0c02\u0c26\u0c3f \u0c2e\u0c28\u0c4d\u0c28\u0c41 \u0c07\u0c26\u0c4d\u0c30\u0c02 \u0c17\u0c33\u0c38\u0c4d\u0c24\u0c47 \u0c05\u0c02\u0c1f\u0c47 \u0c2e\u0c3e\u0c15\u0c41 \u0c2c\u0c4d\u0c30\u0c47\u0c28\u0c4d \u0c32\u0c47\u0c26\u0c3e \u0c2e\u0c3e\u0c15\u0c41 \u0c2a",
    "transliterated": "M\u0101m\u0101 m\u0101 muggu\u1e37a\u1e47 nub\u012b ga\u1e0dar\u0101 indi bakar\u0101 ga\u1e45\u1e47\u1e0da miku p\u0101vuru\u1e47\u1e0di m\u0101ku br\u0113nu\u1e47\u1e0di m\u0101nnu idra\u1e45 ga\u1e37as\u1e6da an\u1e6da m\u0101ku br\u0113nu l\u0113\u1e0d\u0101 m\u0101ku p\u0101"
  }
]