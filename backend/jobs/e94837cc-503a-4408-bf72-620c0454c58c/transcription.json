  {
    "start": 8.9,
    "end": 15.44,
    "text": "\u0c07\u0c30\u0c4b\u0c1c\u0c41 \u0c38\u0c4b\u0c38\u0c3e\u0c2f\u0c1f\u0c3f\u0c32\u0c4b\u0c28\u0c4d\u0c28 \u0c2a\u0c4d\u0c30\u0c3e\u0c2c\u0c4d\u0c32\u0c02\u0c38\u0c4d \u0c17\u0c41\u0c30\u0c3f\u0c02\u0c1a \u0c06\u0c32\u0c1a\u0c41\u0c38\u0c4d\u0c24\u0c41\u0c02\u0c1f\u0c47 \u0c28\u0c3e\u0c15\u0c41 \u0c17\u0c42\u0c38\u0c4d \u0c2a\u0c3f\u0c02\u0c2a\u0c4d\u0c2a\u0c41\u0c32\u0c4d\u0c38\u0c4d \u0c09\u0c38\u0c4d\u0c24\u0c41\u0c02\u0c26\u0c47 \u0c38\u0c30\u0c4d",
    "transliterated": null
  },
  {
    "start": 15.44,
    "end": 18.92,
    "text": "\u0c05\u0c38\u0c32\u0c4d \u0c17\u0c42\u0c38\u0c4d \u0c2a\u0c3f\u0c02\u0c2a\u0c4d\u0c2a\u0c41\u0c32\u0c4d\u0c38\u0c4d \u0c17\u0c42\u0c30\u0c3f\u0c02\u0c1a \u0c05\u0c32\u0c1a\u0c41\u0c38\u0c4d\u0c24\u0c41\u0c24\u0c47 \u0c2e\u0c32\u0c4d\u0c32 \u0c17\u0c42\u0c38\u0c4d \u0c2a\u0c3f\u0c02\u0c2a\u0c4d\u0c2a\u0c41\u0c32\u0c4d\u0c38\u0c4d \u0c35\u0c38\u0c4d\u0c24\u0c41\u0c28\u0c47 \u0c38\u0c3e\u0c30\u0c4d",
    "transliterated": null
