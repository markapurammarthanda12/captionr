  {
    "start": 33.42,
    "end": 63.4,
    "text": "\u0c2e\u0c3e\u0c2e\u0c3e \u0c07\u0c26\u0c4d\u0c26\u0c3f\u0c15\u0c41\u0c02\u0c21\u0c3f \u0c15\u0c41\u0c1f\u0c4d\u0c1f\u0c30\u0c41 \u0c2e\u0c3e\u0c2e\u0c3e",
