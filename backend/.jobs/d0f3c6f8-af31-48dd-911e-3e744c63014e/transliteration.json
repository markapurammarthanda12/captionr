  },
  {
    "start": 65.08,
    "end": 71.1,
    "text": "\u0c2e\u0c3e\u0c2e\u0c3e \u0c2e\u0c3e\u0c28\u0c41 \u0c32\u0c3e \u0c32\u0c3e\u0c07\u0c2b\u0c4d \u0c32\u0c4b \u0c32\u0c3e\u0c07\u0c2b\u0c4d \u0c0e\u0c02\u0c21\u0c47 \u0c38\u0c3f\u0c1f\u0c4d\u0c35\u0c3f\u0c37\u0c3f\u0c02\u0c26\u0c4d \u0c35\u0c3f\u0c37\u0c4d\u0c1a\u0c47\u0c38\u0c4d\u0c2f\u0c02\u0c26\u0c4d \u0c30\u0c3e",
    "transliterated": "\u0c2e\u0c3e\u0c2e\u0c3e \u0c2e\u0c3e\u0c28\u0c41 \u0c32\u0c3e \u0c32\u0c3e\u0c07\u0c2b\u0c4d \u0c32\u0c4b \u0c32\u0c3e\u0c07\u0c2b\u0c4d \u0c0e\u0c02\u0c21\u0c47 \u0c38\u0c3f\u0c1f\u0c4d\u0c35\u0c3f\u0c37\u0c3f\u0c02\u0c26\u0c4d \u0c35\u0c3f\u0c37\u0c4d\u0c1a\u0c47\u0c38\u0c4d\u0c2f\u0c02\u0c26\u0c4d \u0c30\u0c3e"
  },
  {
    "start": 71.1,
    "end": 75.48,
    "text": "\u0c2e\u0c3e\u0c28 \u0c2e\u0c41\u0c17\u0c4d\u0c17\u0c41\u0c30\u0c41\u0c32\u0c4b \u0c15\u0c4b\u0c21\u0c3f \u0c38\u0c1a\u0c4d\u0c1a\u0c3f\u0c2a\u0c47\u0c28\u0c3e \u0c2a\u0c30\u0c32\u0c47\u0c26\u0c4d \u0c2e\u0c3f\u0c24\u0c3e \u0c07\u0c26\u0c4d\u0c26\u0c30\u0c41 \u0c38\u0c02\u0c24\u0c4b\u0c37\u0c02\u0c17\u0c41\u0c02\u0c1f\u0c47 \u0c38\u0c3e\u0c32\u0c4d\u0c21\u0c3e",
    "transliterated": "\u0c2e\u0c3e\u0c28 \u0c2e\u0c41\u0c17\u0c4d\u0c17\u0c41\u0c30\u0c41\u0c32\u0c4b \u0c15\u0c4b\u0c21\u0c3f \u0c38\u0c1a\u0c4d\u0c1a\u0c3f\u0c2a\u0c47\u0c28\u0c3e \u0c2a\u0c30\u0c32\u0c47\u0c26\u0c4d \u0c2e\u0c3f\u0c24\u0c3e \u0c07\u0c26\u0c4d\u0c26\u0c30\u0c41 \u0c38\u0c02\u0c24\u0c4b\u0c37\u0c02\u0c17\u0c41\u0c02\u0c1f\u0c47 \u0c38\u0c3e\u0c32\u0c4d\u0c21\u0c3e"
  },
  {
