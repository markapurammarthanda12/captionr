[
  {
    "start": 0.0,
    "end": 4.98,
    "text": "\u0c05\u0c38\u0c32\u0c4d \u0c17\u0c4d\u0c32\u0c4b\u0c2c\u0c32\u0c4d \u0c35\u0c3e\u0c30\u0c4d\u0c2e\u0c47\u0c36\u0c28\u0c4d \u0c05\u0c02\u0c1f\u0c47\u0c02\u0c1f\u0c4b \u0c26\u0c47\u0c32\u0c4d\u0c38\u0c3e \u0c38\u0c30\u0c4d \u0c2e\u0c3f\u0c15\u0c41? \u0c21\u0c3f\u0c2b\u0c47\u0c28\u0c4d\u0c38\u0c4d \u0c32\u0c4b\u0c2f\u0c30\u0c4d \u0c38\u0c4b\u0c2e\u0c36\u0c47\u0c15\u0c30\u0c4d \u0c17\u0c3e\u0c30\u0c41?",
    "transliterated": "\u0c05\u0c38\u0c32\u0c4d \u0c17\u0c4d\u0c32\u0c4b\u0c2c\u0c32\u0c4d \u0c35\u0c3e\u0c30\u0c4d\u0c2e\u0c47\u0c36\u0c28\u0c4d \u0c05\u0c02\u0c1f\u0c47\u0c02\u0c1f\u0c4b \u0c26\u0c47\u0c32\u0c4d\u0c38\u0c3e \u0c38\u0c30\u0c4d \u0c2e\u0c3f\u0c15\u0c41? \u0c21\u0c3f\u0c2b\u0c47\u0c28\u0c4d\u0c38\u0c4d \u0c32\u0c4b\u0c2f\u0c30\u0c4d \u0c38\u0c4b\u0c2e\u0c36\u0c47\u0c15\u0c30\u0c4d \u0c17\u0c3e\u0c30\u0c41?"
  },
  {
    "start": 4.98,
    "end": 6.22,
    "text": "\u0c28\u0c3e \u0c2a\u0c47\u0c30\u0c41 \u0c38\u0c4b\u0c2a\u0c38\u0c47\u0c15\u0c30\u0c4d \u0c15\u0c3e\u0c26\u0c41",
    "transliterated": "\u0c28\u0c3e \u0c2a\u0c47\u0c30\u0c41 \u0c38\u0c4b\u0c2a\u0c38\u0c47\u0c15\u0c30\u0c4d \u0c15\u0c3e\u0c26\u0c41"
  },
  {
    "start": 6.22,
    "end": 7.62,
    "text": "\u0c38\u0c42\u0c37\u0c3f\u0c28\u0c4d \u0c30\u0c3e \u0c26\u0c4d\u0c35\u0c3e\u0c30\u0c4d\u0c15\u0c3e \u0c2a\u0c4d\u0c30\u0c38\u0c26\u0c4d \u0c17\u0c3e\u0c30\u0c41",
    "transliterated": "\u0c38\u0c42\u0c37\u0c3f\u0c28\u0c4d \u0c30\u0c3e \u0c26\u0c4d\u0c35\u0c3e\u0c30\u0c4d\u0c15\u0c3e \u0c2a\u0c4d\u0c30\u0c38\u0c26\u0c4d \u0c17\u0c3e\u0c30\u0c41"
  },
  {
    "start": 7.62,
    "end": 8.38,
    "text": "\u0c26\u0c4d\u0c35\u0c3e\u0c30\u0c4d\u0c15\u0c3e \u0c2a\u0c4d\u0c30\u0c38\u0c26\u0c4d \u0c06\u0c26\u0c41",
    "transliterated": "\u0c26\u0c4d\u0c35\u0c3e\u0c30\u0c4d\u0c15\u0c3e \u0c2a\u0c4d\u0c30\u0c38\u0c26\u0c4d \u0c06\u0c26\u0c41"
  },
  {
    "start": 8.38,
    "end": 8.94,
    "text": "\u0c2a\u0c3e\u0c21\u0c41 \u0c35\u0c21\u0c41",
    "transliterated": "\u0c2a\u0c3e\u0c21\u0c41 \u0c35\u0c21\u0c41"
  },
  {
    "start": 8.94,
    "end": 15.44,
    "text": "\u0c07\u0c30\u0c4b\u0c1c\u0c41 \u0c38\u0c4b\u0c38\u0c3e\u0c2f\u0c1f\u0c3f\u0c32\u0c4b\u0c28\u0c4d\u0c28 \u0c2a\u0c4d\u0c30\u0c3e\u0c2c\u0c4d\u0c32\u0c02\u0c38\u0c4d \u0c17\u0c41\u0c30\u0c3f\u0c02\u0c1a \u0c06\u0c32\u0c1a\u0c41\u0c38\u0c4d\u0c24\u0c41\u0c02\u0c1f\u0c47 \u0c28\u0c3e\u0c15\u0c41 \u0c17\u0c42\u0c38\u0c4d \u0c2a\u0c3f\u0c02\u0c2a\u0c4d\u0c2a\u0c41\u0c32\u0c4d\u0c38\u0c4d \u0c09\u0c38\u0c4d\u0c24\u0c41\u0c02\u0c26\u0c47 \u0c38\u0c30\u0c4d",
    "transliterated": "\u0c07\u0c30\u0c4b\u0c1c\u0c41 \u0c38\u0c4b\u0c38\u0c3e\u0c2f\u0c1f\u0c3f\u0c32\u0c4b\u0c28\u0c4d\u0c28 \u0c2a\u0c4d\u0c30\u0c3e\u0c2c\u0c4d\u0c32\u0c02\u0c38\u0c4d \u0c17\u0c41\u0c30\u0c3f\u0c02\u0c1a \u0c06\u0c32\u0c1a\u0c41\u0c38\u0c4d\u0c24\u0c41\u0c02\u0c1f\u0c47 \u0c28\u0c3e\u0c15\u0c41 \u0c17\u0c42\u0c38\u0c4d \u0c2a\u0c3f\u0c02\u0c2a\u0c4d\u0c2a\u0c41\u0c32\u0c4d\u0c38\u0c4d \u0c09\u0c38\u0c4d\u0c24\u0c41\u0c02\u0c26\u0c47 \u0c38\u0c30\u0c4d"
  },
  {
    "start": 15.44,
    "end": 18.9,
    "text": "\u0c05\u0c38\u0c32\u0c4d \u0c17\u0c42\u0c38\u0c4d \u0c2a\u0c3f\u0c02\u0c2a\u0c4d\u0c2a\u0c41\u0c32\u0c4d\u0c38\u0c4d \u0c17\u0c42\u0c30\u0c3f\u0c02\u0c1a \u0c06\u0c32\u0c4d\u0c32\u0c3f\u0c38\u0c4d\u0c24\u0c41\u0c24\u0c47 \u0c2e\u0c32\u0c4d\u0c32 \u0c17\u0c42\u0c38\u0c4d \u0c2a\u0c3f\u0c02\u0c2a\u0c4d\u0c2a\u0c41\u0c32\u0c4d\u0c38\u0c4d \u0c35\u0c38\u0c4d\u0c24\u0c41\u0c28\u0c47 \u0c38\u0c3e\u0c30\u0c4d",
    "transliterated": "\u0c05\u0c38\u0c32\u0c4d \u0c17\u0c42\u0c38\u0c4d \u0c2a\u0c3f\u0c02\u0c2a\u0c4d\u0c2a\u0c41\u0c32\u0c4d\u0c38\u0c4d \u0c17\u0c42\u0c30\u0c3f\u0c02\u0c1a \u0c06\u0c32\u0c4d\u0c32\u0c3f\u0c38\u0c4d\u0c24\u0c41\u0c24\u0c47 \u0c2e\u0c32\u0c4d\u0c32 \u0c17\u0c42\u0c38\u0c4d \u0c2a\u0c3f\u0c02\u0c2a\u0c4d\u0c2a\u0c41\u0c32\u0c4d\u0c38\u0c4d \u0c35\u0c38\u0c4d\u0c24\u0c41\u0c28\u0c47 \u0c38\u0c3e\u0c30\u0c4d"
  },
  {
    "start": 19.9,
    "end": 22.2,
    "text": "\u0c09\u0c28\u0c4d\u0c28\u0c32\u0c41 \u0c32\u0c47\u0c28\u0c4b\u0c32\u0c4d\u0c32\u0c41 \u0c12\u0c15 \u0c1c\u0c3e\u0c17\u0c32\u0c41 \u0c09\u0c02\u0c21\u0c3e\u0c26\u0c4d\u0c26\u0c3e \u0c38\u0c3e\u0c30\u0c4d",
    "transliterated": "\u0c09\u0c28\u0c4d\u0c28\u0c32\u0c41 \u0c32\u0c47\u0c28\u0c4b\u0c32\u0c4d\u0c32\u0c41 \u0c12\u0c15 \u0c1c\u0c3e\u0c17\u0c32\u0c41 \u0c09\u0c02\u0c21\u0c3e\u0c26\u0c4d\u0c26\u0c3e \u0c38\u0c3e\u0c30\u0c4d"
  },
  {
    "start": 22.2,
    "end": 24.6,
    "text": "\u0c2e\u0c3f\u0c32\u0c41 \u0c09\u0c28\u0c4d\u0c28\u0c3e\u0c30\u0c41 \u0c15\u0c3f\u0c02\u0c26\u0c30\u0c3e \u0c15\u0c3e\u0c28\u0c4d \u0c2e\u0c47\u0c2e\u0c41 \u0c32\u0c47\u0c28\u0c4b\u0c32\u0c41 \u0c2e\u0c3f\u0c32\u0c41 \u0c38\u0c3e\u0c30\u0c4d",
    "transliterated": "\u0c2e\u0c3f\u0c32\u0c41 \u0c09\u0c28\u0c4d\u0c28\u0c3e\u0c30\u0c41 \u0c15\u0c3f\u0c02\u0c26\u0c30\u0c3e \u0c15\u0c3e\u0c28\u0c4d \u0c2e\u0c47\u0c2e\u0c41 \u0c32\u0c47\u0c28\u0c4b\u0c32\u0c41 \u0c2e\u0c3f\u0c32\u0c41 \u0c38\u0c3e\u0c30\u0c4d"
  },
  {
    "start": 24.6,
    "end": 28.08,
    "text": "\u0c15\u0c4b\u0c1f\u0c4d \u0c32\u0c4b \u0c09\u0c28\u0c4d\u0c28\u0c3e\u0c32\u0c41 \u0c32\u0c47\u0c28\u0c4b\u0c32\u0c41 \u0c05\u0c28\u0c47 \u0c24\u0c46\u0c21\u0c3e \u0c09\u0c02\u0c21\u0c3e\u0c26\u0c41",
    "transliterated": "\u0c15\u0c4b\u0c1f\u0c4d \u0c32\u0c4b \u0c09\u0c28\u0c4d\u0c28\u0c3e\u0c32\u0c41 \u0c32\u0c47\u0c28\u0c4b\u0c32\u0c41 \u0c05\u0c28\u0c47 \u0c24\u0c46\u0c21\u0c3e \u0c09\u0c02\u0c21\u0c3e\u0c26\u0c41"
  },
  {
    "start": 28.08,
    "end": 58.08,
    "text": "\u0c07\u0c02\u0c26\u0c41\u0c15\u0c4b\u0c1f\u0c4d\u0c1f\u0c3e\u0c32\u0c4d \u0c38\u0c3e\u0c30\u0c4d \u0c07\u0c2a\u0c41\u0c21\u0c4d \u0c15\u0c4b\u0c1f\u0c4d\u0c1f\u0c32\u0c4b \u0c09\u0c28\u0c4d\u0c28\u0c32\u0c4d\u0c32\u0c02\u0c26\u0c30\u0c3f \u0c07\u0c21\u0c41\u0c28\u0c4d\u0c28\u0c3e\u0c30\u0c41 \u0c2e\u0c30\u0c41 \u0c32\u0c47\u0c28\u0c3e\u0c32\u0c4d\u0c32\u0c41 \u0c32\u0c47\u0c28\u0c3e\u0c32\u0c4d\u0c32\u0c41 \u0c38\u0c42\u0c38\u0c3f\u0c28\u0c4d\u0c28\u0c30\u0c3e \u0c38\u0c3e\u0c30\u0c4d \u0c32\u0c47\u0c28\u0c3e\u0c32\u0c4d\u0c32\u0c41\u0c02\u0c32\u0c02\u0c1f\u0c47 \u0c05\u0c02\u0c24\u0c3e \u0c1a\u0c3f\u0c28\u0c4d\u0c28 \u0c1a\u0c42",
    "transliterated": "\u0c07\u0c02\u0c26\u0c41\u0c15\u0c4b\u0c1f\u0c4d\u0c1f\u0c3e\u0c32\u0c4d \u0c38\u0c3e\u0c30\u0c4d \u0c07\u0c2a\u0c41\u0c21\u0c4d \u0c15\u0c4b\u0c1f\u0c4d\u0c1f\u0c32\u0c4b \u0c09\u0c28\u0c4d\u0c28\u0c32\u0c4d\u0c32\u0c02\u0c26\u0c30\u0c3f \u0c07\u0c21\u0c41\u0c28\u0c4d\u0c28\u0c3e\u0c30\u0c41 \u0c2e\u0c30\u0c41 \u0c32\u0c47\u0c28\u0c3e\u0c32\u0c4d\u0c32\u0c41 \u0c32\u0c47\u0c28\u0c3e\u0c32\u0c4d\u0c32\u0c41 \u0c38\u0c42\u0c38\u0c3f\u0c28\u0c4d\u0c28\u0c30\u0c3e \u0c38\u0c3e\u0c30\u0c4d \u0c32\u0c47\u0c28\u0c3e\u0c32\u0c4d\u0c32\u0c41\u0c02\u0c32\u0c02\u0c1f\u0c47 \u0c05\u0c02\u0c24\u0c3e \u0c1a\u0c3f\u0c28\u0c4d\u0c28 \u0c1a\u0c42"
  },
  {
    "start": 58.08,
    "end": 60.08,
    "text": "\u0c24\u0c47\u0c32\u0c41\u0c02\u0c1f\u0c4d \u0c07\u0c35\u0c02\u0c21\u0c3f \u0c24\u0c3e\u0c2f\u0c30\u0c41 \u0c17\u0c3e\u0c30\u0c41 \u0c1c\u0c46\u0c2a\u0c4d\u0c24\u0c41\u0c28\u0c3e\u0c30\u0c41 \u0c17\u0c3e\u0c30\u0c41",
    "transliterated": "\u0c24\u0c47\u0c32\u0c41\u0c02\u0c1f\u0c4d \u0c07\u0c35\u0c02\u0c21\u0c3f \u0c24\u0c3e\u0c2f\u0c30\u0c41 \u0c17\u0c3e\u0c30\u0c41 \u0c1c\u0c46\u0c2a\u0c4d\u0c24\u0c41\u0c28\u0c3e\u0c30\u0c41 \u0c17\u0c3e\u0c30\u0c41"
  },
  {
    "start": 60.08,
    "end": 65.08,
    "text": "\u0c24\u0c24\u0c3f\u0c37\u0c4d \u0c05\u0c15\u0c3e\u0c21\u0c3f\u0c02\u0c1f\u0c41 \u0c07\u0c02\u0c21\u0c3f\u0c2f\u0c28\u0c4d \u0c15\u0c3e\u0c28\u0c4d\u0c38\u0c4d\u0c1f\u0c41\u0c2a\u0c47\u0c36\u0c28\u0c4d \u0c06\u0c2f\u0c02 \u0c38\u0c4d\u0c1f\u0c3f\u0c32\u0c4d \u0c05\u0c28\u0c4d\u0c15\u0c4d\u0c30\u0c3f\u0c2e\u0c3f\u0c28\u0c32\u0c4d \u0c1f\u0c3f\u0c32\u0c4d \u0c2a\u0c4d\u0c30\u0c42\u0c2b\u0c4d",
