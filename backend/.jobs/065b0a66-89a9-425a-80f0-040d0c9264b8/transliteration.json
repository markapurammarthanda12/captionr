  },
  {
    "start": 6.46,
    "end": 7.16,
    "text": "\u0c38\u0c42\u0c37\u0c3f\u0c28\u0c4d\u0c30\u0c3e\u0c26\u0c4d\u0c35\u0c3e\u0c30\u0c4d\u0c15\u0c3e",
    "transliterated": "Sushinradhvarakaa"
  },
  {
    "start": 7.16,
    "end": 7.98,
    "text": "\u0c2a\u0c4d\u0c30\u0c38\u0c26\u0c4d\u0c17\u0c3e\u0c30\u0c41\u0c26\u0c4d\u0c35\u0c3e\u0c30\u0c4d\u0c15\u0c3e",
    "transliterated": "Prasadhgarudhvarakaa"
  },
  {
    "start": 7.98,
    "end": 8.62,
    "text": "\u0c2a\u0c4d\u0c30\u0c38\u0c26\u0c4d\u0c06\u0c26\u0c41\u0c2a\u0c3e\u0c21\u0c41",
    "transliterated": "Prasadhadaupada"
  },
  {
    "start": 8.62,
    "end": 11.9,
    "text": "\u0c35\u0c21\u0c41\u0c07\u0c30\u0c4b\u0c1c\u0c41\u0c38\u0c4b\u0c38\u0c3e\u0c2f\u0c1f\u0c3f\u0c32\u0c4b\u0c28\u0c4d\u0c28",
