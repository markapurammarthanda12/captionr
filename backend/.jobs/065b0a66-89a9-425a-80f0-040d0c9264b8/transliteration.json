  },
  {
    "start": 47.4,
    "end": 49.08,
    "text": "\u0c35\u0c3e\u0c27\u0c3f\u0c02\u0c1a\u0c41\u0c15\u0c41\u0c02\u0c1f\u0c02\u0c2f\u0c4b\u0c05\u0c28\u0c4d\u0c28\u0c3e\u0c30\u0c4d",
