[
  {
    "start": 0.0,
    "end": 1.8,
    "text": "\u0c05\u0c38\u0c32\u0c4d\u0c17\u0c4d\u0c32\u0c4b\u0c2c\u0c32\u0c4d\u0c35\u0c3e\u0c30\u0c4d\u0c2e\u0c47\u0c36\u0c28\u0c4d",
    "transliterated": "Asalglobelwarmeshan"
  },
  {
    "start": 1.8,
    "end": 2.52,
    "text": "\u0c05\u0c02\u0c1f\u0c47\u0c02\u0c1f\u0c4b\u0c26\u0c47\u0c32\u0c4d\u0c38\u0c3e\u0c38\u0c30\u0c4d",
    "transliterated": "Antentodelsasar"
  },
  {
    "start": 2.52,
    "end": 3.82,
    "text": "\u0c2e\u0c3f\u0c15\u0c41?\u0c21\u0c3f\u0c2b\u0c47\u0c28\u0c4d\u0c38\u0c4d\u0c32\u0c4b\u0c2f\u0c30\u0c4d",
    "transliterated": "Mikudifensloyar"
  },
  {
    "start": 3.82,
    "end": 5.2,
    "text": "\u0c38\u0c4b\u0c2e\u0c36\u0c47\u0c15\u0c30\u0c4d\u0c17\u0c3e\u0c30\u0c41?\u0c28\u0c3e",
    "transliterated": "Somashakargarunar"
  },
  {
    "start": 5.2,
    "end": 6.1,
    "text": "\u0c2a\u0c47\u0c30\u0c41\u0c38\u0c4b\u0c2a\u0c38\u0c47\u0c15\u0c30\u0c4d\u0c15\u0c3e\u0c26\u0c41",
