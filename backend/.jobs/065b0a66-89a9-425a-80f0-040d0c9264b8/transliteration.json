  },
  {
    "start": 11.9,
    "end": 13.16,
    "text": "\u0c2a\u0c4d\u0c30\u0c3e\u0c2c\u0c4d\u0c32\u0c02\u0c38\u0c4d\u0c17\u0c41\u0c30\u0c3f\u0c02\u0c1a\u0c06\u0c32\u0c1a\u0c41\u0c38\u0c4d\u0c24\u0c41\u0c02\u0c1f\u0c47",
