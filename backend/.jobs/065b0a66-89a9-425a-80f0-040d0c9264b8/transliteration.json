  },
  {
    "start": 13.16,
    "end": 14.82,
    "text": "\u0c28\u0c3e\u0c15\u0c41\u0c17\u0c42\u0c38\u0c4d\u0c2a\u0c3f\u0c02\u0c2a\u0c4d\u0c2a\u0c41\u0c32\u0c4d\u0c38\u0c4d",
