  },
  {
    "start": 20.38,
    "end": 21.34,
    "text": "\u0c09\u0c28\u0c4d\u0c28\u0c4b\u0c32\u0c4d\u0c32\u0c41\u0c32\u0c47\u0c28\u0c4b\u0c32\u0c4d\u0c32\u0c41\u0c12\u0c15",
